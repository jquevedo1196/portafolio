---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const skills = [
  { category: "Cloud", items: ["AWS", "OCI", "EKS", "ECS", "EC2", "Lambda", "S3", "RDS"] },
  { category: "DevOps / SRE", items: ["Kubernetes", "Docker", "Jenkins", "GitHub Actions", "Terraform", "Ansible", "Helm", "Artifactory"] },
  { category: "Observability", items: ["Dynatrace", "Grafana", "Prometheus", "OpenTelemetry", "CloudWatch", "Kibana"] },
  { category: "Languages", items: ["Python", "Go", "Java", "Shell", "PL/SQL", "NodeJS"] },
  { category: "AI / ML", items: ["Scikit-learn", "TensorFlow", "MLflow", "FastAPI", "Pandas", "NLP", "LLMs", "FastMCP"] },
  { category: "Security", items: ["SonarQube", "Snyk", "RBAC", "IAM"] },
];

const featuredProjects = [
  {
    title: "AI-Powered CI/CD Log Analyzer",
    description: "Multi-agent RCA system for CI/CD pipelines. Orchestrator, Worker, and Auditor agents collaborate through MCP Gateway to analyze logs, generate root cause analysis, and validate results against hallucination.",
    tags: ["Python", "Multi-Agent", "MCP", "FastMCP", "Oracle"],
    github: "#",
    status: "In Progress"
  },
  {
    title: "EKS Fargate Production Cluster",
    description: "Production-ready EKS Fargate cluster with RBAC, monitoring, auto-scaling, and GitOps deployment. Full IaC with Terraform.",
    tags: ["Kubernetes", "AWS", "Terraform", "Helm"],
    github: "https://github.com/jquevedo1196",
  },
  {
    title: "ClearCase to Git Migration Toolkit",
    description: "Enterprise SCM migration framework with custom APIs and GUI frontend. Handles branch mapping, history preservation, and team onboarding.",
    tags: ["Python", "Git", "Flet", "APIs"],
    github: "#",
    status: "Internal @ Oracle"
  },
];

const experience = [
  {
    date: "Apr 2025 - Present",
    title: "Principal DevOps Engineer",
    company: "Oracle",
    description: "Modernizing legacy systems (ClearCase → Git) and driving AI integration into DevOps workflows as part of Oracle's AI adoption initiative. Building a multi-agent RCA system for CI/CD pipelines. Reduced pipeline times by 35%."
  },
  {
    date: "Feb 2024 - Apr 2025",
    title: "DevOps & L2 Support Engineer",
    company: "Santander Bank USA",
    description: "Incident response and root-cause analysis across 20+ production services on AWS. SLA-driven troubleshooting with Dynatrace and Grafana."
  },
  {
    date: "Jun 2022 - Oct 2023",
    title: "Head of DevOps",
    company: "Macropay",
    description: "Built DevOps from zero in a company with no prior culture. Led on-prem → AWS migration (Lambda, ECS, EKS), built deployment automation with Python/Boto3 and Terraform, created ephemeral dev environments, trained devs into DevOps roles, and led 15 engineers across 30+ microservices."
  },
  {
    date: "Oct 2021 - Jun 2022",
    title: "DevOps Lead",
    company: "TV Azteca Digital",
    description: "Unified iOS/Android CI/CD with Fastlane and GitHub Actions. Added SonarQube quality gates, defined branching strategy, and built Smartsheet webhook integrations for PM-triggered self-service deployments. Weekly → daily releases."
  },
  {
    date: "Jul 2015 - Oct 2021",
    title: "DevOps Founder & Developer Lead",
    company: "Aiontech",
    description: "Founded the DevOps practice from zero — introduced Docker, built the full CI/CD pipeline with Jenkins and SonarQube, defined branching strategy, and migrated legacy Java 6/7 to Spring Boot on AWS (EC2 → ECS). Delivered platforms for 10+ clients including HSBC."
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <canvas id="particles"></canvas>
    <div class="container">
      <div class="hero-content">
        <p class="hero-greeting">$ whoami</p>
        <h1 class="hero-name">Jesús Quevedo</h1>
        <p class="hero-title">
          <span id="typewriter"></span><span class="cursor"></span>
        </p>
        <p class="hero-description">
          I build platforms that engineering teams can actually trust —
          and the AI tools that make them smarter.
          9+ years shipping infrastructure for fintech, banking, media,
          and enterprise. Now applying AI to DevOps at Oracle.
        </p>
        <div class="btn-group">
          <a href={`${base}projects/`} class="btn btn-primary">View Projects</a>
          <a href={`${base}resume/`} class="btn btn-outline">Download Resume</a>
        </div>

        <!-- Stats -->
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number" data-target="9">0</span><span class="stat-plus">+</span>
            <span class="stat-label">Years</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-target="10">0</span><span class="stat-plus">+</span>
            <span class="stat-label">Companies</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-target="35">0</span><span class="stat-plus">%</span>
            <span class="stat-label">Faster CI/CD</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-target="15">0</span>
            <span class="stat-label">Engineers Led</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Currently Building Spotlight -->
  <section id="spotlight">
    <div class="container">
      <div class="section-header">
        <p class="section-label">$ tail -f build.log</p>
        <h2 class="section-title">Currently Building</h2>
        <div class="section-line"></div>
      </div>
      <div class="spotlight-card">
        <div class="spotlight-header">
          <div>
            <div class="spotlight-badge">
              <span class="spotlight-pulse"></span>
              ACTIVE DEVELOPMENT
            </div>
            <h3 class="spotlight-title">AI-Powered CI/CD Log Analyzer</h3>
            <p class="spotlight-subtitle">Multi-agent RCA system with 3 agent roles, Agent Gateway, and MCP Gateway for enterprise CI/CD pipelines @ Oracle</p>
          </div>
        </div>

        <div class="spotlight-architecture">
          <div class="arch-flow-animated">
            <div class="arch-node-anim" data-step="1">
              <span class="arch-icon">&#9881;</span>
              <span class="arch-label">Orchestrator</span>
              <span class="arch-desc">Receives task</span>
            </div>
            <div class="arch-arrow-anim" data-step="2"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-gateway-anim" data-step="2">
              <span class="arch-label">Agent Gateway</span>
              <span class="arch-desc">Access control</span>
            </div>
            <div class="arch-arrow-anim" data-step="3"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-node-anim" data-step="3">
              <span class="arch-icon">&#9881;</span>
              <span class="arch-label">Workers</span>
              <span class="arch-desc">Collect data</span>
            </div>
            <div class="arch-arrow-anim" data-step="4"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-gateway-anim" data-step="4">
              <span class="arch-label">MCP Gateway</span>
              <span class="arch-desc">Tool access</span>
            </div>
            <div class="arch-arrow-anim" data-step="5"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-node-anim" data-step="5">
              <span class="arch-icon">&#128196;</span>
              <span class="arch-label">Initial RCA</span>
              <span class="arch-desc">Report generated</span>
            </div>
            <div class="arch-arrow-anim" data-step="6"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-node-anim" data-step="6">
              <span class="arch-icon">&#9989;</span>
              <span class="arch-label">Auditor</span>
              <span class="arch-desc">Validates</span>
            </div>
            <div class="arch-arrow-anim" data-step="7"><span class="arrow-head">&rarr;</span></div>
            <div class="arch-node-anim" data-step="7">
              <span class="arch-icon">&#127942;</span>
              <span class="arch-label">Final RCA</span>
              <span class="arch-desc">Validated result</span>
            </div>
          </div>
        </div>

        <div class="spotlight-phases">
          <div class="phase phase-complete">
            <div class="phase-indicator">
              <span class="phase-dot phase-dot-active"></span>
              <span class="phase-line phase-line-done"></span>
            </div>
            <div class="phase-content">
              <p class="phase-label">Phase 1 <span class="phase-badge-complete">COMPLETE</span></p>
              <p class="phase-name">Multi-Agent Orchestration</p>
              <p class="phase-desc">3-role agent architecture with retry loop</p>
            </div>
          </div>
          <div class="phase phase-complete">
            <div class="phase-indicator">
              <span class="phase-dot phase-dot-active"></span>
              <span class="phase-line phase-line-done"></span>
            </div>
            <div class="phase-content">
              <p class="phase-label">Phase 2 <span class="phase-badge-complete">COMPLETE</span></p>
              <p class="phase-name">RCA Generation & Validation</p>
              <p class="phase-desc">Workers generate RCA, Auditor validates against hallucination</p>
            </div>
          </div>
          <div class="phase phase-complete">
            <div class="phase-indicator">
              <span class="phase-dot phase-dot-active"></span>
              <span class="phase-line phase-line-done"></span>
            </div>
            <div class="phase-content">
              <p class="phase-label">Phase 3 <span class="phase-badge-complete">COMPLETE</span></p>
              <p class="phase-name">Gateway Security & Scaling</p>
              <p class="phase-desc">Agent Gateway + MCP Gateway for access control</p>
            </div>
          </div>
          <div class="phase phase-current">
            <div class="phase-indicator">
              <span class="phase-dot phase-dot-current"></span>
              <span class="phase-line"></span>
            </div>
            <div class="phase-content">
              <p class="phase-label">Phase 4 <span class="phase-badge-current">IN PROGRESS</span></p>
              <p class="phase-name">Real Scenario Testing</p>
              <p class="phase-desc">Finalizing validation against real CI/CD failure scenarios</p>
            </div>
          </div>
          <div class="phase phase-upcoming">
            <div class="phase-indicator">
              <span class="phase-dot phase-dot-upcoming"></span>
            </div>
            <div class="phase-content">
              <p class="phase-label">Phase 5</p>
              <p class="phase-name">Human-in-the-Loop Feedback</p>
              <p class="phase-desc">Agent learns from fix feedback to propose solutions autonomously</p>
            </div>
          </div>
        </div>
        <div class="spotlight-tags">
          <span class="card-tag">Python</span>
          <span class="card-tag">Multi-Agent</span>
          <span class="card-tag">FastMCP</span>
          <span class="card-tag">Agent Gateway</span>
          <span class="card-tag">MCP Gateway</span>
          <span class="card-tag">Oracle</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section id="projects">
    <div class="container">
      <div class="section-header">
        <p class="section-label">$ ls projects/</p>
        <h2 class="section-title">Some of My Projects</h2>
        <div class="section-line"></div>
      </div>
      <div class="projects-grid">
        {featuredProjects.map(p => (
          <div class="card project-card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <h3>{p.title}</h3>
              {p.status && <span class="card-tag">{p.status}</span>}
            </div>
            <p>{p.description}</p>
            <div style="margin-bottom:1rem;">
              {p.tags.map(t => <span class="card-tag">{t}</span>)}
            </div>
            <div class="project-links">
              {p.github !== "#" && <a href={p.github} target="_blank" rel="noopener">GitHub &rarr;</a>}
            </div>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:2rem;">
        <a href={`${base}projects/`} class="btn btn-outline">All Projects &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <div class="section-header">
        <p class="section-label">$ git log --oneline career</p>
        <h2 class="section-title">Experience</h2>
        <div class="section-line"></div>
      </div>
      <div class="timeline">
        {experience.map(e => (
          <div class="timeline-item">
            <p class="timeline-date">{e.date}</p>
            <h3 class="timeline-title">{e.title}</h3>
            <p class="timeline-company">{e.company}</p>
            <p class="timeline-description">{e.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="container">
      <div class="section-header">
        <p class="section-label">$ kubectl get skills</p>
        <h2 class="section-title">Skills & Tools</h2>
        <div class="section-line"></div>
      </div>
      <div class="skills-grid">
        {skills.map(s => (
          <div class="card skill-category">
            <h3>{s.category}</h3>
            <div class="skill-items">
              {s.items.map(item => (
                <span class="skill-item">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container" style="text-align:center;">
      <div class="section-header" style="text-align:center;">
        <p class="section-label">$ ssh jesus@connect</p>
        <h2 class="section-title">Let's Connect</h2>
        <div class="section-line" style="margin:0.75rem auto 0;"></div>
      </div>
      <p style="color:var(--text-secondary); max-width:500px; margin:0 auto 2rem;">
        Open to discussing cloud architecture, DevOps practices,
        or opportunities where DevOps meets AI.
      </p>
      <div class="btn-group" style="justify-content:center;">
        <a href="mailto:jenriqueqt@gmail.com" class="btn btn-primary">Send Email</a>
        <a href="https://linkedin.com/in/jquevedo1196" target="_blank" rel="noopener" class="btn btn-outline">LinkedIn</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // === Typewriter ===
  const titles = [
    "Principal DevOps Engineer @ Oracle",
    "AI Engineer — MSc in Artificial Intelligence",
  ];
  const el = document.getElementById("typewriter");
  let titleIdx = 0, charIdx = 0, deleting = false;

  function typeLoop() {
    const current = titles[titleIdx];
    if (!deleting) {
      el.textContent = current.substring(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        setTimeout(() => { deleting = true; typeLoop(); }, 2000);
        return;
      }
      setTimeout(typeLoop, 55);
    } else {
      el.textContent = current.substring(0, charIdx);
      charIdx--;
      if (charIdx < 0) {
        deleting = false;
        charIdx = 0;
        titleIdx = (titleIdx + 1) % titles.length;
        setTimeout(typeLoop, 400);
        return;
      }
      setTimeout(typeLoop, 30);
    }
  }
  setTimeout(typeLoop, 600);

  // === Animated counters ===
  function animateCounters() {
    document.querySelectorAll(".stat-number").forEach(counter => {
      const target = +counter.dataset.target;
      const duration = 1500;
      const start = performance.now();
      function update(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        counter.textContent = Math.floor(eased * target);
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    });
  }
  setTimeout(animateCounters, 1200);

  // === Fade-in on scroll ===
  document.querySelectorAll("section:not(.hero)").forEach(s => s.classList.add("fade-in"));
  const obs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add("visible"); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll(".fade-in").forEach(el => obs.observe(el));

  // === Particle network background ===
  const canvas = document.getElementById("particles");
  if (canvas) {
    const ctx = canvas.getContext("2d");
    let w, h, particles;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = canvas.parentElement.offsetHeight;
    }

    function init() {
      resize();
      particles = Array.from({ length: 60 }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 2 + 0.5,
      }));
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);

      // Draw connections
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 150) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(0, 255, 136, ${0.08 * (1 - dist / 150)})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      // Draw & move particles
      particles.forEach(p => {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(0, 255, 136, 0.3)";
        ctx.fill();

        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
      });

      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener("resize", resize);
  }
</script>
